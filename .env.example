# Coral-SAAS — local dev environment.
# Copy to .env.local and fill in. NEVER commit .env.local.

# --- Database & queue ---
DATABASE_URL=postgres://coral:coral@localhost:5432/coral_saas
REDIS_URL=redis://localhost:6379

# --- Server ports ---
PORT=8080                            # api
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- Logging ---
RUST_LOG=info,api=debug,worker=debug

# --- LLM (free tier banca'o) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- GitHub App (creá la app en https://github.com/settings/apps) ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-app.private-key.pem
GITHUB_WEBHOOK_SECRET=

# --- GitHub OAuth (separado del App para login — ver §8.1) ---
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Sessions & worker JWT ---
SESSION_SECRET=                      # min 32 random bytes, hex
WORKER_JWT_SECRET=                   # min 32 random bytes, hex

# --- Cloudflare R2 ---
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_BUCKET=coral-saas-wiki
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- GitHub Packages (for modo-bo-ui-lib) ---
GITHUB_PACKAGES_TOKEN=ghp_...        # PAT with read:packages

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
