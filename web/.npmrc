# GitHub Packages registry for the @playsistemico scope (modo-bo-ui-lib).
# Set GITHUB_PACKAGES_TOKEN in your shell or in Railway env vars to a PAT
# with `read:packages` scope. Do NOT commit a token here.
@playsistemico:registry=https://npm.pkg.github.com/
//npm.pkg.github.com/:_authToken=${GITHUB_PACKAGES_TOKEN}
